# 数据库 (SQLite 开发 / PostgreSQL 生产)
DATABASE_URL=

# JWT 密钥
JWT_SECRET=change-me-secret-key
JWT_PREVIOUS_SECRETS=
JWT_EXPIRE_MINUTES=10080

# 卡密 Peper（不要泄露）
CARD_PEPPER=change-me-card-pepper
CARD_PREVIOUS_PEPPERS=

ENABLE_DEV_PAYMENT=false

# QQ 邮箱 SMTP
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-auth-code

ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
