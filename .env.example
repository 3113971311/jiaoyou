# ============================================================
# 数据库
# ============================================================
DATABASE_URL=postgresql://social:socal123@postgres:5432/social_dating

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://redis:6379

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ============================================================
# 卡密 Peper（不要泄露！）
# ============================================================
CARD_PEPPER=change-me-card-pepper

# ============================================================
# MinIO / 对象存储
# ============================================================
S3_ENDPOINT=minio
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=social-dating
S3_USE_SSL=false

# ============================================================
# QQ 邮箱 SMTP
# ============================================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-auth-code

# ============================================================
# 地图 API（高德/腾讯 二选一）
# ============================================================
AMAP_API_KEY=your-amap-key

# ============================================================
# 应用
# ============================================================
APP_PORT=3000
APP_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
