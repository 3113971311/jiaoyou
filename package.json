{
  "name": "social-dating",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "dev:user": "pnpm --filter user-app dev",
    "dev:admin": "pnpm --filter admin-app dev",
    "build": "pnpm --filter user-app build && pnpm --filter admin-app build",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "pnpm --filter backend db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "sharp",
      "esbuild"
    ]
  }
}
