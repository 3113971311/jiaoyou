generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  nickname      String?
  avatarUrl     String?
  avatarStaging String?
  gender        String?
  birthday      DateTime?
  bio           String?
  location      String?
  vipExpiresAt  DateTime?
  warningCount  Int       @default(0)
  isAdmin       Boolean   @default(false)
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens     RefreshToken[]
  sentMessages      Message[]         @relation("Sender")
  moments           Moment[]
  reviewSubmissions ReviewQueue[]     @relation("Submitter")
  reviewDecisions   ReviewQueue[]     @relation("Reviewer")
  vipOrders         VipOrder[]
  matchQueues       MatchQueue[]      @relation("Matcher")
  matchedWith       MatchQueue[]      @relation("Matched")
  cardBatches       CardBatch[]
  cardRedemptions   Card[]
  sentReports       Report[]          @relation("Reporter")
  warningsReceived  Warning[]
  warningsIssued    Warning[]         @relation("WarnedBy")
  blacklistGiven    Blacklist[]       @relation("Blocker")
  blacklistReceived Blacklist[]       @relation("Blocked")
  notifications     Notification[]
  followerRelations Follow[]          @relation("Follower")
  followedRelations Follow[]          @relation("Followed")
  matchDailyCounts  MatchDailyCount[]
  configEdits        SiteConfig[]      @relation("ConfigUpdater")
  convAsUser1       Conversation[]    @relation("ConvUser1")
  convAsUser2       Conversation[]    @relation("ConvUser2")
  momentComments    MomentComment[]
  momentLikes       MomentLike[]

  @@index([vipExpiresAt])
  @@index([status])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  family    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followedId String
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
}

model Conversation {
  id            String    @id @default(cuid())
  user1Id       String
  user2Id       String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  user1    User      @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  contentType    String   @default("text")
  imageUrl       String?
  status         String   @default("sent")
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Moment {
  id            String    @id @default(cuid())
  userId        String
  contentText   String?
  status        String    @default("pending_review")
  reviewComment String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  images  MomentImage[]
  likes   MomentLike[]
  comments MomentComment[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model MomentImage {
  id           String   @id @default(cuid())
  momentId     String
  imageUrl     String
  thumbnailUrl String?
  publicUrl    String?
  reviewStatus String   @default("pending")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)

  @@index([momentId])
}

model MomentLike {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  createdAt DateTime @default(now())

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
}

model MomentComment {
  id        String   @id @default(cuid())
  momentId  String
  userId    String
  content   String
  createdAt DateTime @default(now())

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([momentId, createdAt])
}

model ReviewQueue {
  id            String    @id @default(cuid())
  imageUrl      String
  thumbnailUrl  String?
  imageType     String
  relatedId     String?
  submittedBy   String
  status        String    @default("pending")
  reviewedBy    String?
  reviewComment String?
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?

  submitter User @relation("Submitter", fields: [submittedBy], references: [id], onDelete: Cascade)
  reviewer  User? @relation("Reviewer", fields: [reviewedBy], references: [id])

  @@index([status, submittedAt])
}

model MatchQueue {
  id           String    @id @default(cuid())
  userId       String
  scope        String
  city         String?
  province     String?
  latitude     Float?
  longitude    Float?
  preferGender String
  status       String    @default("waiting")
  matchedWith  String?
  matchedAt    DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  user    User  @relation("Matcher", fields: [userId], references: [id], onDelete: Cascade)
  matched User? @relation("Matched", fields: [matchedWith], references: [id])

  @@index([status, expiresAt])
  @@index([userId])
}

model MatchDailyCount {
  id     String   @id @default(cuid())
  userId String
  date   DateTime
  count  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model CardBatch {
  id               String   @id @default(cuid())
  batchName        String
  denominationDays Int
  expireDays       Int      @default(7)
  quantity         Int
  generatedBy      String
  note             String?
  createdAt        DateTime @default(now())

  creator User   @relation(fields: [generatedBy], references: [id])
  cards   Card[]
}

model Card {
  id               String    @id @default(cuid())
  batchId          String
  cardCode         String    @unique
  codeHash         String
  denominationDays Int
  status           String    @default("unused")
  usedBy           String?
  usedAt           DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())

  batch CardBatch @relation(fields: [batchId], references: [id])
  user  User?     @relation(fields: [usedBy], references: [id])

  @@index([codeHash])
  @@index([batchId])
  @@index([status])
}

model VipOrder {
  id        String    @id @default(cuid())
  userId    String
  cardId    String?
  days      Int
  orderType String
  vipBefore DateTime?
  vipAfter  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Report {
  id         String    @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String    @default("pending")
  handledBy  String?
  result     String?
  createdAt  DateTime  @default(now())
  handledAt  DateTime?

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Warning {
  id                  String   @id @default(cuid())
  userId              String
  warnedBy            String
  reason              String
  relatedChatImageUrl String?
  createdAt           DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  warner User @relation("WarnedBy", fields: [warnedBy], references: [id])

  @@index([userId])
}

model Blacklist {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String?
  relatedId String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model SensitiveWord {
  id        String   @id @default(cuid())
  word      String   @unique
  level     String
  createdBy String
  createdAt DateTime @default(now())
}

model SiteConfig {
  configKey   String    @id
  configValue String
  valueType   String    @default("text")
  description String?
  updatedBy   String?
  updatedAt   DateTime  @default(now())

  updater User? @relation("ConfigUpdater", fields: [updatedBy], references: [id])
}
